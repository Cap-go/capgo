{
  "name": "capgo_plugin_replica",
  "logpush": true,
  "compatibility_date": "2026-04-21",
  "main": "./index.ts",
  "compatibility_flags": [
    "nodejs_compat",
    "nodejs_compat_populate_process_env"
  ],
  "workers_dev": false,
  "upload_source_maps": true,
  "env": {
    "local": {
      "name": "capgo_plugin_replica-local",
      "vars": {
        "ENV_NAME": "capgo_plugin-local-eu",
        "CAPGO_PREVENT_BACKGROUND_FUNCTIONS": "true"
      }
    }
  }
}
