<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Hardened-runtime entitlements for the App Store Connect key helper (a SwiftUI
  app hosting a WKWebView). Developer ID + hardened runtime is required for
  notarization; WebKit needs JIT for its JavaScript engine, and the app loads
  Apple's site over the network.
-->
<plist version="1.0">
<dict>
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.network.client</key>
  <true/>
</dict>
</plist>
